---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Page Not Found | Ross Volkwein"
  description="This page doesn't exist or has been moved."
  canonicalPath="/404"
  ogImage="/favicon.svg"
  noindex={true}
>
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6 font-sans">
    <p class="font-mono text-sm uppercase tracking-[0.25em] text-slate-400 dark:text-slate-500 mb-4">Error</p>
    <h1 class="text-8xl sm:text-9xl font-extrabold tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-sky-500 dark:from-indigo-400 dark:to-sky-300 mb-6">
      404
    </h1>
    <p class="font-mono text-slate-500 dark:text-slate-400 max-w-sm mb-8 leading-relaxed">
      This page doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-6 py-3 text-sm font-semibold uppercase tracking-[0.15em] hover:opacity-80 transition-opacity"
    >
      ← Back to home
    </a>
  </section>
</Layout>
